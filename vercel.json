{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "buildCommand": "node scripts/build-vercel.mjs",
    "outputDirectory": "dist",
    "trailingSlash": true,
    "headers": [
        {
            "source": "/js/slides-manifest.js",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "no-cache, no-store, must-revalidate"
                }
            ]
        }
    ]
}
